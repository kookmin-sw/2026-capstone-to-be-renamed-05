APP_ENV="local"
NEXT_PUBLIC_APP_ENV="local"
ASSET_STORAGE_DRIVER="local"

# Local PostgreSQL. If schema is omitted, LOCAL_DATABASE_SCHEMA is appended.
DATABASE_URL="postgresql://cpa:cpa@localhost:5432/cpa_jobs"
LOCAL_DATABASE_SCHEMA="local"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=4000
API_PUBLIC_BASE_URL="http://localhost:4000"
WEB_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
ENABLE_SWAGGER=true

# Optional AI features
OPENAI_API_KEY=""

# Local company logo uploads. Files are written under apps/web/public/uploads,
# which is ignored by git and served by the local Next.js dev server.
LOCAL_ASSET_DIR="apps/web/public/uploads"
LOCAL_ASSET_PUBLIC_BASE_URL="http://localhost:3000/uploads"
NEXT_PUBLIC_LOCAL_ASSET_PUBLIC_BASE_URL="http://localhost:3000/uploads"

# AWS company logo uploads. Set APP_ENV=aws and ASSET_STORAGE_DRIVER=s3
# in production. Prefer IAM role credentials for the API server.
AWS_DATABASE_SCHEMA="public"
AWS_REGION="ap-northeast-2"
S3_ASSET_BUCKET="your-public-logo-bucket"
S3_PUBLIC_BASE_URL="https://your-public-logo-bucket.s3.ap-northeast-2.amazonaws.com"
S3_PRESIGN_EXPIRES_SECONDS=300
NEXT_PUBLIC_S3_PUBLIC_BASE_URL="https://your-public-logo-bucket.s3.ap-northeast-2.amazonaws.com"

# Production EC2 + Caddy + S3 static web hosting values live in
# deploy/production.env.example. For static web builds, set:
# NEXT_PUBLIC_API_BASE_URL="/api"
