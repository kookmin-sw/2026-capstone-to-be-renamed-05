# Local development defaults.
# Copy to .env.local for local work, or use deploy/production.env.example for EC2.

APP_ENV=local
NEXT_PUBLIC_APP_ENV=local
NODE_ENV=development

DATABASE_URL=postgresql://cpa:cpa@localhost:5432/cpa_jobs
LOCAL_DATABASE_SCHEMA=local

JWT_SECRET=replace-with-a-local-development-secret-at-least-32-chars
PORT=4000
API_PUBLIC_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000
AUTH_COOKIE_SECURE=false
ENABLE_SWAGGER=true

ASSET_STORAGE_DRIVER=local
RESUME_STORAGE_DRIVER=local
LOCAL_ASSET_DIR=apps/web/public/uploads
LOCAL_ASSET_PUBLIC_BASE_URL=http://localhost:3000/uploads
NEXT_PUBLIC_LOCAL_ASSET_PUBLIC_BASE_URL=http://localhost:3000/uploads
LOCAL_RESUME_DIR=var/uploads/resumes
# Optional. Leave empty to store mock company image URLs as web-relative paths.
MOCK_PUBLIC_ASSET_BASE_URL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
# Optional. Leave empty to inherit OPENAI_MODEL / OPENAI_REASONING_EFFORT.
OPENAI_JOB_FIT_MODEL=
OPENAI_JOB_FIT_REASONING_EFFORT=
