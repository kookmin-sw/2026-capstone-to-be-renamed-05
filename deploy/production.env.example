DOMAIN=accountit.example.com
ACME_EMAIL=admin@example.com
APP_ENV=aws
NEXT_PUBLIC_APP_ENV=aws
ASSET_STORAGE_DRIVER=s3

POSTGRES_USER=cpa
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=cpa_jobs
DATABASE_URL=postgresql://cpa:replace-with-a-long-random-password@postgres:5432/cpa_jobs?schema=public
AWS_DATABASE_SCHEMA=public

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
PORT=4000
API_PUBLIC_BASE_URL=https://accountit.example.com/api
WEB_ORIGIN=https://accountit.example.com
ENABLE_SWAGGER=false

OPENAI_API_KEY=

AWS_REGION=ap-northeast-2
S3_WEB_BUCKET=accountit-web
S3_WEB_ENDPOINT=http://accountit-web.s3-website.ap-northeast-2.amazonaws.com
S3_WEB_HOST=accountit-web.s3-website.ap-northeast-2.amazonaws.com

S3_ASSET_BUCKET=accountit-assets
S3_PUBLIC_BASE_URL=https://accountit-assets.s3.ap-northeast-2.amazonaws.com
S3_PRESIGN_EXPIRES_SECONDS=300

NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_S3_PUBLIC_BASE_URL=https://accountit-assets.s3.ap-northeast-2.amazonaws.com

# Optional: scripts/backup-postgres.sh uploads compressed dumps here when set.
S3_BACKUP_BUCKET=
