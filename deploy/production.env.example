DOMAIN=accountit.example.com
ACME_EMAIL=admin@example.com
APP_ENV=aws
NEXT_PUBLIC_APP_ENV=aws
ASSET_STORAGE_DRIVER=s3
RESUME_STORAGE_DRIVER=s3
NEXT_PUBLIC_CANONICAL_WEB_ORIGIN=https://app.accountit.example.com
NEXT_PUBLIC_REDIRECT_WEB_HOSTS=accountit-web.s3-website.ap-northeast-2.amazonaws.com

POSTGRES_USER=cpa
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=cpa_jobs
DATABASE_URL=postgresql://cpa:replace-with-a-long-random-password@postgres:5432/cpa_jobs?schema=public
AWS_DATABASE_SCHEMA=public

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
PORT=4000
API_PUBLIC_BASE_URL=https://api.accountit.example.com
WEB_ORIGIN=http://accountit-web.s3-website.ap-northeast-2.amazonaws.com,https://app.accountit.example.com
# Keep true for HTTPS production. Set false only for temporary HTTP EC2 demos.
AUTH_COOKIE_SECURE=true
ENABLE_SWAGGER=false

# Used by GitHub Actions -> POST /ops/deploy.
DEPLOY_API_TOKEN=replace-with-a-long-random-deploy-token
DEPLOY_BRANCH=develop
DEPLOY_SCRIPT_PATH=scripts/deploy-ec2.sh
DEPLOY_LOCK_FILE=.run/deploy.lock
DEPLOY_LOG_FILE=.run/deploy.log
# Optional. Leave blank to auto-enable only for temporary HTTP EC2 demos, where
# AUTH_COOKIE_SECURE=false. Set true when the API public URL should follow the
# current EC2 public IP; set false when using a stable API domain or Elastic IP.
DEPLOY_AUTO_UPDATE_EC2_HOST=
# Optional. Leave blank to auto-enable only when AUTH_COOKIE_SECURE=false and
# S3_WEB_ENDPOINT is set. Set true for temporary HTTP EC2 demos with S3 so the
# redirect target follows the current EC2 public IP.
DEPLOY_AUTO_UPDATE_WEB_HOST=
DEPLOY_API_SCHEME=http
# Leave blank to use PORT, then fallback to 8080.
DEPLOY_API_PORT=
# Static EC2 web server used as the canonical origin for HTTP demos.
DEPLOY_WEB_PORT=3000
# Leave blank to derive from the current EC2 public IP and DEPLOY_WEB_PORT.
DEPLOY_WEB_BASE_URL=
# Restart the EC2 static web server after static build. Leave blank to auto-enable
# only for temporary HTTP demos where AUTH_COOKIE_SECURE=false.
DEPLOY_RESTART_WEB_STATIC=
# Optional manual override when EC2 metadata is unavailable.
DEPLOY_PUBLIC_HOST=

OPENAI_API_KEY=

AWS_REGION=ap-northeast-2
S3_WEB_BUCKET=accountit-web
S3_WEB_ENDPOINT=http://accountit-web.s3-website.ap-northeast-2.amazonaws.com
S3_WEB_HOST=accountit-web.s3-website.ap-northeast-2.amazonaws.com
# Comma-separated prefixes preserved by deploy:web:s3 when --delete runs.
# Keep this when S3_WEB_BUCKET is shared with images, resumes, or backups.
S3_WEB_PROTECTED_PREFIXES=company-logos,company-backgrounds,resumes,postgres,backups,out

S3_ASSET_BUCKET=accountit-assets
S3_PUBLIC_BASE_URL=https://accountit-assets.s3.ap-northeast-2.amazonaws.com
S3_PRESIGN_EXPIRES_SECONDS=300

S3_RESUME_BUCKET=accountit-resumes
S3_RESUME_KEY_PREFIX=resumes

NEXT_PUBLIC_API_BASE_URL=https://api.accountit.example.com
NEXT_PUBLIC_S3_PUBLIC_BASE_URL=https://accountit-assets.s3.ap-northeast-2.amazonaws.com
# Optional. Leave empty to serve seeded mock company images from the web origin.
MOCK_PUBLIC_ASSET_BASE_URL=

# Optional: scripts/backup-postgres.sh uploads compressed dumps here when set.
S3_BACKUP_BUCKET=
