{
  "name": "cpa-job-platform",
  "version": "1.0.0",
  "description": "CPA-focused job curation platform prototype.",
  "private": true,
  "engines": {
    "node": "24.x",
    "npm": ">=11"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run build --workspace @cpa/shared && concurrently -n api,web -c cyan,magenta \"npm run start:dev --workspace @cpa/api\" \"npm run dev:web\"",
    "dev:api": "npm run build --workspace @cpa/shared && npm run start:dev --workspace @cpa/api",
    "dev:web": "npm run build --workspace @cpa/shared && npm run dev --workspace @cpa/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:mock": "tsx prisma/mock.ts",
    "prisma:map-company-assets": "tsx prisma/map-company-logos.ts",
    "prisma:map-company-logos": "tsx prisma/map-company-logos.ts",
    "prisma:import:saramin": "tsx prisma/import-saramin.ts",
    "prisma:import:kicpa": "tsx prisma/import-kicpa.ts",
    "build:web:static": "node scripts/build-web-static.mjs",
    "deploy:web:s3": "bash scripts/deploy-web-s3.sh",
    "backup:postgres": "bash scripts/backup-postgres.sh"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "prisma": "^7.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kookmin-sw/2026-capstone-85.git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/kookmin-sw/2026-capstone-85/issues"
  },
  "homepage": "https://github.com/kookmin-sw/2026-capstone-85#readme"
}
