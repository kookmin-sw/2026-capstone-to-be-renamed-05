generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  JOB_SEEKER
  COMPANY
  ADMIN
}

enum CompanyType {
  BIG4
  LOCAL_ACCOUNTING_FIRM
  MID_SMALL_ACCOUNTING_FIRM
  FINANCIAL_COMPANY
  GENERAL_COMPANY
  PUBLIC_INSTITUTION
}

enum JobFamily {
  AUDIT
  TAX
  FAS
  DEAL
  INTERNAL_ACCOUNTING
  IN_HOUSE
}

enum EmploymentType {
  FULL_TIME
  CONTRACT
  INTERN
  PART_TIME
}

enum KicpaCondition {
  REQUIRED
  PREFERRED
  NONE
  UNCLEAR
}

enum TraineeStatus {
  AVAILABLE
  UNAVAILABLE
  UNCLEAR
}

enum DeadlineType {
  FIXED_DATE
  UNTIL_FILLED
  ALWAYS_OPEN
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionType {
  CREATE
  UPDATE
}

enum AiSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetPurpose {
  COMPANY_LOGO
}

enum AssetStatus {
  PENDING
  READY
}

model User {
  id                  String   @id @default(uuid())
  username            String   @unique
  passwordHash        String
  displayName         String?
  role                UserRole
  jobFilterPreference Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  ownedCompany                      Company?                   @relation("CompanyOwner")
  jobPresets                        UserJobPreset[]
  jobSubmissions                    JobSubmission[]            @relation("JobSubmissionSubmitter")
  reviewedJobSubmissions            JobSubmission[]            @relation("JobSubmissionReviewer")
  companyProfileSubmissions         CompanyProfileSubmission[] @relation("CompanyProfileSubmissionSubmitter")
  reviewedCompanyProfileSubmissions CompanyProfileSubmission[] @relation("CompanyProfileSubmissionReviewer")
  uploadedAssets                    Asset[]                    @relation("AssetUploader")
  bookmarks                         Bookmark[]
  resumes                           Resume[]
}

model Company {
  id                  String      @id @default(uuid())
  name                String      @unique
  type                CompanyType
  websiteUrl          String?
  logoAssetId         String?     @unique
  description         String?
  businessNumber      String?
  employeeTrend       Json?
  externalLinks       String[]    @default([])
  tags                String[]    @default([])
  employeeCount       Int?
  averageSalary       Int?
  foundedYear         Int?
  recentAttritionRate Float?
  ownerUserId         String      @unique
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  owner              User                       @relation("CompanyOwner", fields: [ownerUserId], references: [id])
  logoAsset          Asset?                     @relation("CompanyLogoAsset", fields: [logoAssetId], references: [id], onDelete: SetNull)
  assets             Asset[]                    @relation("CompanyAssets")
  metadata           CompanyMetadata?
  jobs               Job[]
  jobSubmissions     JobSubmission[]
  profileSubmissions CompanyProfileSubmission[]
}

model Asset {
  id           String       @id @default(uuid())
  purpose      AssetPurpose
  status       AssetStatus  @default(PENDING)
  bucket       String
  region       String
  key          String       @unique
  publicUrl    String
  contentType  String
  byteSize     Int
  originalName String?
  uploadedById String
  companyId    String
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  uploadedBy     User     @relation("AssetUploader", fields: [uploadedById], references: [id])
  company        Company  @relation("CompanyAssets", fields: [companyId], references: [id], onDelete: Cascade)
  logoForCompany Company? @relation("CompanyLogoAsset")

  @@index([companyId, purpose, status])
  @@index([uploadedById, status])
}

model CompanyMetadata {
  companyId                 String   @id
  careerVerificationSignals String[] @default([])
  careerVerificationNote    String?
  careerVerificationSource  String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Source {
  id          String   @id @default(uuid())
  name        String   @unique
  baseUrl     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs Job[]
}

model Label {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs JobLabel[]
}

model Job {
  id                           String         @id @default(uuid())
  title                        String
  description                  String
  companyId                    String
  sourceId                     String
  originalUrl                  String
  jobFamily                    JobFamily
  employmentType               EmploymentType
  companyType                  CompanyType
  kicpaCondition               KicpaCondition
  traineeStatus                TraineeStatus
  practicalTrainingInstitution Boolean?
  minExperienceYears           Int?
  maxExperienceYears           Int?
  location                     String?
  deadlineType                 DeadlineType
  deadline                     DateTime?
  status                       JobStatus      @default(OPEN)
  lastCheckedAt                DateTime
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt

  company            Company         @relation(fields: [companyId], references: [id])
  source             Source          @relation(fields: [sourceId], references: [id])
  labels             JobLabel[]
  aiSuggestions      AiSuggestion[]
  approvedSubmission JobSubmission?  @relation("ApprovedJobSubmission")
  editSubmissions    JobSubmission[] @relation("TargetJobSubmission")

  @@index([status, deadline])
  @@index([jobFamily])
  @@index([companyType])
  @@index([traineeStatus])
}

model JobLabel {
  jobId   String
  labelId String
  job     Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([jobId, labelId])
}

model UserJobPreset {
  id              String    @id @default(uuid())
  userId          String
  filterState     Json
  autoLabel       String
  filterSignature String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastUsedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, filterSignature])
  @@index([userId, createdAt])
}

model JobSubmission {
  id                           String           @id @default(uuid())
  companyId                    String
  submittedById                String
  submissionType               SubmissionType   @default(CREATE)
  targetJobId                  String?
  title                        String
  description                  String
  originalUrl                  String?
  jobFamily                    JobFamily
  employmentType               EmploymentType
  kicpaCondition               KicpaCondition   @default(UNCLEAR)
  traineeStatus                TraineeStatus    @default(UNCLEAR)
  practicalTrainingInstitution Boolean?
  minExperienceYears           Int?
  maxExperienceYears           Int?
  location                     String?
  deadlineType                 DeadlineType
  deadline                     DateTime?
  status                       SubmissionStatus @default(PENDING)
  adminNote                    String?
  approvedJobId                String?          @unique
  reviewedById                 String?
  reviewedAt                   DateTime?
  createdAt                    DateTime         @default(now())
  updatedAt                    DateTime         @updatedAt

  company     Company @relation(fields: [companyId], references: [id])
  submittedBy User    @relation("JobSubmissionSubmitter", fields: [submittedById], references: [id])
  reviewedBy  User?   @relation("JobSubmissionReviewer", fields: [reviewedById], references: [id])
  approvedJob Job?    @relation("ApprovedJobSubmission", fields: [approvedJobId], references: [id])
  targetJob   Job?    @relation("TargetJobSubmission", fields: [targetJobId], references: [id])

  @@index([companyId, status])
  @@index([submittedById, status])
  @@index([targetJobId, status])
}

model CompanyProfileSubmission {
  id            String           @id @default(uuid())
  companyId     String
  submittedById String
  proposed      Json
  status        SubmissionStatus @default(PENDING)
  adminNote     String?
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  company     Company @relation(fields: [companyId], references: [id])
  submittedBy User    @relation("CompanyProfileSubmissionSubmitter", fields: [submittedById], references: [id])
  reviewedBy  User?   @relation("CompanyProfileSubmissionReviewer", fields: [reviewedById], references: [id])

  @@index([companyId, status])
  @@index([submittedById, status])
}

model AiSuggestion {
  id        String             @id @default(uuid())
  jobId     String
  summary   String
  tags      String[]           @default([])
  risks     String[]           @default([])
  rawJson   Json
  status    AiSuggestionStatus @default(PENDING)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ImportRun {
  id           String   @id @default(uuid())
  sourceName   String
  status       String
  totalRows    Int      @default(0)
  importedRows Int      @default(0)
  errorRows    Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())
}

enum BookmarkTargetType {
  JOB
  COMPANY
}

model Bookmark {
  id         String             @id @default(uuid())
  userId     String
  targetType BookmarkTargetType
  targetId   String
  createdAt  DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId, targetType, createdAt])
}

model Resume {
  id           String   @id @default(uuid())
  userId       String
  fileName     String
  fileUrl      String
  contentType  String
  byteSize     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
